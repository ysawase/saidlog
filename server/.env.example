# AssemblyAI のAPIキー（https://www.assemblyai.com/dashboard で取得）
ASSEMBLYAI_API_KEY=your_api_key_here

# Supabase（ダッシュボード > Project Settings > API で確認）
# service_role キーは秘匿必須。クライアント側に置かないこと
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Vercel Cron の認証用シークレット（任意。設定するとcleanupエンドポイントを保護できる）
# CRON_SECRET=

# サーバーのポート（省略時 3000）
PORT=3000
