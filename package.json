    "@supabase/supabase-js": "^2.108.1",
    "assemblyai": "^4.9.0",
    "capacitor-plugin-cdv-purchase": "^13.17.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "ffmpeg-static": "^5.3.0",
    "form-data": "^4.0.5",
    "googleapis": "^173.0.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "playwright": "^1.61.1"
  },
  "overrides": {
    "shell-quote": "^1.8.4"
