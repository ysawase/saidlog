    "test": "node --test \"tests/**/*.test.mjs\"",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
